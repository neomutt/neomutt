msgid "                              Full email with headers and body"
msgstr "                              Plena retpoŝtaĵo kun ĉapoj kaj korpo"

#: usage.c:273
msgid "  -i, --include <file>        Include body file"
msgstr "  -i, --include <inkluzivaĵo> Inkluvizigi korpodosieron"

#: usage.c:274
msgid "  -s, --subject <subject>     Set Subject:"
msgstr "  -s, --subject <subject>     Specifi temon"

#: usage.c:275
msgid "  -- <address> [...]          Add To: addresses"
msgstr "  -- <adreso>  [...]          Aldoni alsendotajn adresojn"

#. L10N: Examples: Filenames and email subjects may be translated
#: usage.c:284
msgid "  neomutt flatcap --subject 'Meeting' < meeting.txt"
msgstr "  neomutt flatcap --subject 'Kunveno' < kunveno.txt"

#: usage.c:285
msgid "  neomutt jim@example.com --cc bob@example.com --subject 'Party' --include party.txt"
msgstr "  neomutt jim@example.com --cc bob@example.com --subject 'Festo' --include festo.txt"

#: usage.c:286
msgid "  neomutt --subject 'Receipts' --attach receipt1.pdf receipt2.pdf -- rocco"
msgstr "  neomutt --subject 'Kvitancoj' --attach kvitanco1.pdf kvitanco2.pdf -- rocco"

#: usage.c:287
msgid "  cat secret.txt | neomutt gahr --subject 'Secret' --crypto"
msgstr "  cat sekreto.txt | neomutt gahr --subject 'Sekreto' --crypto"

#: usage.c:300
msgid "Running NeoMutt with no options will read the config and start the TUI."
msgstr "Plenumigo de NeoMutt kun neniuj opcioj analizos la agordodosieron kaj startigos la terminalan fasadon."

#: usage.c:301
msgid "By default, it will open the Index Dialog with the $spool_file Mailbox."
msgstr "Apriore ĝi malfermos la indeksan dialogujon kun la leterkesto $spool_file."

#: usage.c:304
msgid "These options cause NeoMutt to check a mailbox for mail."
msgstr "Per ĉi tiuj opcioj NeoMutt kontrolas leterkeston por poŝtaĵo."

#: usage.c:305
msgid "If the condition isn't matched, NeoMutt exits."
msgstr "Se la kondiĉo ne estas plenumita, NeoMutt finiĝas."

#: usage.c:306
msgid "  -p, --postponed       Resume postponed email"
msgstr "  -p, --postponed       Restarigi prokrastitan retpoŝtaĵon"

#: usage.c:307
msgid "  -Z, --check-new-mail  Check for new mail"
msgstr "  -Z, --check-new-mail  Kontroli novajn retpoŝtaĵojn"

#: usage.c:308
msgid "  -z, --check-any-mail  Check for any mail"
msgstr "  -z, --check-any-mail  Kontroli ĉiajn retpoŝtaĵojn"

#. L10N: Parameters in <>s may be translated
#: usage.c:312
msgid "These options change the starting behavior:"
msgstr "Ĉi tiuj opcioj ŝanĝas kiel NeoMutt startas:"

#: usage.c:313
msgid "  -f, --folder <mailbox>      Open this mailbox"
msgstr "  -f, --folder <leterkesto>   Malfermi specifitan leterkeston"

#: usage.c:314
msgid "  -G, --nntp-browser          Open NNTP browser"
msgstr "  -G, --nntp-browser          Malfermi NNTP-foliumilon"

#: usage.c:315
msgid "  -g, --nntp-server <server>  Use this NNTP server"
msgstr "  -g, --nntp-server <servilo> Uzi specifitan NNTP-servilon"

#: usage.c:316
msgid "  -R, --read-only             Open mailbox read-only"
msgstr "  -R, --read-only             Malfermi leterkeston kiel nurlegan"

#: usage.c:317
msgid "  -y, --browser               Open mailbox browser"
msgstr "  -y, --browser               Malfermi leterkestan foliumilon"

#. L10N: Examples: Path may be translated
#: usage.c:326
msgid "  neomutt --folder ~/mail --check-new-mail"
msgstr "  neomutt --folder ~/poŝtaĵoj --check-new-mail"

#: usage.c:327
msgid "  neomutt --postponed"
msgstr "  neomutt --postponed"

#: usage.c:328
msgid "  neomutt --browser"
msgstr "  neomutt --browser"

