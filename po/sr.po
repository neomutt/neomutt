msgid "  -F, --config <file>         Use this user config file"
msgstr "  -F, --config <конфиг>       Користи дату корисничку конфигурацију"

#: usage.c:140 usage.c:147
msgid "                              May be used multiple times"
msgstr "                              Може се користити више пута"

#: usage.c:143
msgid "These options override the config:"
msgstr "Ове опције заобилазе конфигурацију:"

#: usage.c:144
msgid "  -m, --mbox-type <type>      Set default mailbox type"
msgstr "  -m, --mbox-type <врста>     Поставља подразумевану врсту сандучета"

#: usage.c:145
msgid "                              May be: maildir, mbox, mh, mmdf"
msgstr "                              Може бити: maildir, mbox, mh, mmdf"

#: usage.c:146
msgid "  -e, --command <command>     Run extra commands"
msgstr "  -e, --command <наредба>     Покреће додатне наредбе"

#: usage.c:150
msgid "These logging options override the config:"
msgstr "Ове опције бележења у дневник заобилазе конфигурацију:"

#: usage.c:151
msgid "  -d, --debug-level <level>   Set logging level"
msgstr "  -d, --debug-level <ниво>    Поставља ниво бележења у дневник"

#: usage.c:152
msgid "                              0 (off), 1 (low) .. 5 (high)"
msgstr "                              0 (искључено), 1 (низак) .. 5 (висок)"

#: usage.c:153
msgid "  -l, --debug-file <file>     Set logging file"
msgstr "  -l, --debug-file <дато>     Поставља датотеку дневника"

#: usage.c:154
msgid "                              Default file '~/.neomuttdebug0'"
msgstr "                Подразумевана датотека је „~/.neomuttdebug0“"

#: usage.c:158 usage.c:160 usage.c:198 usage.c:200 usage.c:235 usage.c:237
#: usage.c:279 usage.c:281 usage.c:321 usage.c:323
msgid "Examples:"
msgstr "Примери:"

#. L10N: Examples: Filenames may be translated
#: usage.c:163
msgid "  neomutt --no-system-config"
msgstr "  neomutt --no-system-config"

#: usage.c:164
msgid "  neomutt --config work.rc"
msgstr "  neomutt --config posao.rc"

#: usage.c:165
msgid "  neomutt --config work.rc --config colours.rc"
msgstr "  neomutt --config posao.rc --config boje.rc"

#: usage.c:168
msgid "  neomutt --mbox-type maildir"
msgstr "  neomutt --mbox-type maildir"

#: usage.c:169
msgid "  neomutt --command 'set ask_cc = yes'"
msgstr "  neomutt --command 'set ask_cc = yes'"

#: usage.c:172
msgid "  neomutt --debug-level 2"
msgstr "  neomutt --debug-level 2"

#: usage.c:173
msgid "  neomutt --debug-level 5 --debug-file neolog"
msgstr "  neomutt --debug-level 5 --debug-file neolog"

#: usage.c:176
msgid "See also:"
msgstr "Видети и:"

#: usage.c:177
msgid "- Config files: https://neomutt.org/guide/configuration"
msgstr "- Конфигурационе датотеке: https://neomutt.org/guide/configuration"

#. L10N: Parameters in <>s may be translated
#: usage.c:191
msgid "  -h, --help           Overview of command line options"
msgstr "  -h, --help           Преглед опција командне линије"

#: usage.c:192
msgid "  -h, --help <mode>    Detailed help for: shared, help, info, send, tui, all"
msgstr "  -h, --help <режим>   Детаљна помоћ за: shared, help, info, send, tui, all"

#: usage.c:193
msgid "  -v, --version        NeoMutt version and build parameters"
msgstr "  -v, --version        Верзија и параметри изградње NeoMutt-а"

#: usage.c:194
msgid "  -vv, --license       NeoMutt Copyright and license"
msgstr "  -vv, --license       Ауторска права и лиценца NeoMutt-а"

#. L10N: Examples
#: usage.c:203
msgid "  neomutt --help info"
msgstr "  neomutt --help info"

#: usage.c:204
msgid "  neomutt --license"
msgstr "  neomutt --license"

#. L10N: Parameters in <>s may be translated
#: usage.c:218
msgid "  -A, --alias <alias> [...]   Lookup email aliases"
msgstr "  -A, --alias <алијас> [...]  Тражи мејл алијасе"

#: usage.c:219
msgid "                              Multiple aliases can be looked up (space-separated)"
msgstr "                              Може се тражити више алијаса (раздвојених размацима)"

#: usage.c:222
msgid "  -D, --dump-config           Dump all the config options"
msgstr "  -D, --dump-config           Истоварује све конфигурационе опције"

#: usage.c:223
msgid "  -DD, --dump-changed-config  Dump the changed config options"
msgstr "  -DD, --dump-changed-config  Као -D, али приказује само измењену конфигурацију"

#: usage.c:226
msgid "  -Q, --query <option> [...]  Query config options"
msgstr "  -Q, --query <опција> [...]  Испитује конфигурационе опције"

#: usage.c:227
msgid "                              Multiple options can be looked up (space-separated)"
msgstr "                              Може се тражити више опција (раздвојених размацима)"

#: usage.c:229
msgid "Modify the -D and -Q options:"
msgstr "Измена опција -D и -Q:"

#: usage.c:230
msgid "  -O, --with-docs             Add one-liner documentation"
msgstr "  -O, --with-docs             Додаје кратак опис"

#: usage.c:231
msgid "  -S, --hide-sensitive        Hide the value of sensitive options"
msgstr "  -S, --hide-sensitive        Сакрива вредност осетљивих опција"

#. L10N: Examples
#: usage.c:240
msgid "  neomutt --alias flatcap gahr"
msgstr "  neomutt --alias flatcap gahr"

#: usage.c:241
msgid "  neomutt --dump-config --with-docs"
msgstr "  neomutt --dump-config --with-docs"

#: usage.c:242
msgid "  neomutt --dump-changed-config --hide-sensitive"
msgstr "  neomutt --dump-changed-config --hide-sensitive"

#: usage.c:243
msgid "  neomutt --with-docs --query alias_format index_format"
msgstr "  neomutt --with-docs --query alias_format index_format"

#: usage.c:256
msgid "These options can supply everything NeoMutt needs to send an email."
msgstr "Ове опције могу обезедити све што NeoMutt-у треба за слање мејла."

#: usage.c:257
msgid "If any parts are missing, NeoMutt will start the TUI to ask for them."
msgstr "Ако било шта недостаје, NeoMutt ће покренути TUI да за то пита."

#: usage.c:258
msgid "Addresses may be used before the options, or after a -- marker."
msgstr "Адресе се могу користити пре опција, или после ознаке „--“."

#: usage.c:259
msgid "Aliases may be used in place of addresses."
msgstr "Уместо адреса, могу се користити и алијаси."

#. L10N: Parameters in <>s may be translated
#: usage.c:263
msgid "  -a, --attach <file> [...]   Attach files"
msgstr "  -a, --attach <дато> [...]   Прилаже датотеке"

#: usage.c:264
msgid "                              Terminated by -- or another option"
msgstr "                              Завршава се „--“ или другом опцијом"

#: usage.c:265
msgid "  -b, --bcc <address>         Add Bcc: address"
msgstr "  -b, --bcc <адреса>          Додаје Bcc: адресу"

#: usage.c:266
msgid "  -C, --crypto                Use crypto (signing/encryption)"
msgstr "  -C, --crypto                Користи крипто (потписивање/шифровање)"

#: usage.c:267
msgid "                              Must be set up in the config file"
msgstr "                              Мора бити подешен у конфигурацији"

#: usage.c:268
msgid "  -c, --cc <address>          Add Cc: address"
msgstr "  -c, --cc <адреса>           Додаје Cc: адресу"

#: usage.c:269
msgid "  -E, --edit-message          Edit message (draft/include)"
msgstr "  -E, --edit-message          Уређује поруку"

#: usage.c:270
msgid "                              (supplied by -H or -i)"
msgstr "                              (задату преко -H или -i)"

#: usage.c:271
msgid "  -H, --draft <file>          Use draft email file"
msgstr "  -H, --draft <скица>         Користи скицу мејла"

#: usage.c:272
msgid "                              Full email with headers and body"
msgstr "                              Потпуни мејл са заглављима и телом"

#: usage.c:273
msgid "  -i, --include <file>        Include body file"
msgstr "  -i, --include <укључивање>  Укључује датотеку тела"

#: usage.c:274
msgid "  -s, --subject <subject>     Set Subject:"
msgstr "  -s, --subject <тема>        Поставља Subject:"

#: usage.c:275
msgid "  -- <address> [...]          Add To: addresses"
msgstr "  -- <адреса> [...]           Додаје To: адресе"

#. L10N: Examples: Filenames and email subjects may be translated
#: usage.c:284
msgid "  neomutt flatcap --subject 'Meeting' < meeting.txt"
msgstr "  neomutt flatcap --subject 'Састанак' < sastanak.txt"

#: usage.c:285
msgid "  neomutt jim@example.com --cc bob@example.com --subject 'Party' --include party.txt"
msgstr "  neomutt pera@primer.com --cc zika@primer.com -s 'Журка' --include zurka.txt"

#: usage.c:286
msgid "  neomutt --subject 'Receipts' --attach receipt1.pdf receipt2.pdf -- rocco"
msgstr "  neomutt -s 'Рачуни' --attach racun1.pdf racun2.pdf -- rocco"

#: usage.c:287
msgid "  cat secret.txt | neomutt gahr --subject 'Secret' --crypto"
msgstr "  cat tajna.txt | neomutt gahr --subject 'Тајна' --crypto"

#: usage.c:300
msgid "Running NeoMutt with no options will read the config and start the TUI."
msgstr "Покретање NeoMutt-а без опција ће учитати конфигурацију и покренути TUI."

#: usage.c:301
msgid "By default, it will open the Index Dialog with the $spool_file Mailbox."
msgstr "Подразумевано, отвориће се дијалог индекса са сандучетом $spool_file."

#: usage.c:304
msgid "These options cause NeoMutt to check a mailbox for mail."
msgstr "Ове опције чине да MeoMutt провери сандуче."

#: usage.c:305
msgid "If the condition isn't matched, NeoMutt exits."
msgstr "Ако услов није испуњен, NeoMutt излази."

#: usage.c:306
msgid "  -p, --postponed       Resume postponed email"
msgstr "  -p, --postponed       Наставља одложени мејл"

#: usage.c:307
msgid "  -Z, --check-new-mail  Check for new mail"
msgstr "  -Z, --check-new-mail  Проверава нову пошту"

#: usage.c:308
msgid "  -z, --check-any-mail  Check for any mail"
msgstr "  -z, --check-any-mail  Проверава било какву пошту"

#. L10N: Parameters in <>s may be translated
#: usage.c:312
msgid "These options change the starting behavior:"
msgstr "Ове опције мењају понашање при покретању:"

#: usage.c:313
msgid "  -f, --folder <mailbox>      Open this mailbox"
msgstr "  -f, --folder <сандуче>      Отвара дато сандуче"

#: usage.c:314
msgid "  -G, --nntp-browser          Open NNTP browser"
msgstr "  -G, --nntp-browser          Отвара NNTP прегледач"

#: usage.c:315
msgid "  -g, --nntp-server <server>  Use this NNTP server"
msgstr "  -g, --nntp-server <сервер>  Користи дати NNTP сервер"

#: usage.c:316
msgid "  -R, --read-only             Open mailbox read-only"
msgstr "  -R, --read-only             Отвара сандуче само за читање"

#: usage.c:317
msgid "  -y, --browser               Open mailbox browser"
msgstr "  -y, --browser               Отвара прегледач сандучића"

#. L10N: Examples: Path may be translated
#: usage.c:326
msgid "  neomutt --folder ~/mail --check-new-mail"
msgstr "  neomutt --folder ~/mail --check-new-mail"

#: usage.c:327
msgid "  neomutt --postponed"
msgstr "  neomutt --postponed"

#: usage.c:328
msgid "  neomutt --browser"
msgstr "  neomutt --browser"

