#: alias/commands.c:364
msgid "Define an alias (name to email address)"
msgstr "Задаје алијас (назив у мејл адресу)"

#: alias/commands.c:365
msgid "alias [ -group <name> ... ] <key> <address> [,...] [ # <comments> ]"
msgstr "alias [ -group <назив> ... ] <тастер> <адреса> [,...] [ # <коментари> ]"

#: alias/commands.c:368
msgid "Define a list of alternate email addresses for the user"
msgstr "Задаје листу алтернативних мејл адреса корисника"

#: alias/commands.c:369
msgid "alternates [ -group <name> ... ] <regex> [ <regex> ... ]"
msgstr "alternates [ -group <назив> ... ] <регизр> [ <регизр> ... ]"

#: alias/commands.c:372
msgid "Add addresses to an address group"
msgstr "Додаје адресе у групу адреса"

#: alias/commands.c:373
msgid "group [ -group <name> ... ] { -rx <regex> ... | -addr <address> ... }"
msgstr "group [ -group <назив> ... ] { -rx <регизр> ... | -addr <адреса> ... }"

#: alias/commands.c:376
msgid "Add address to the list of mailing lists"
msgstr "Додаје адресу у списак мејлинг листа"

#: alias/commands.c:377
msgid "lists [ -group <name> ... ] <regex> [ ... ]"
msgstr "lists [ -group <назив> ... ] <регизр> [ ... ]"

#: alias/commands.c:380
msgid "Add address to the list of subscribed mailing lists"
msgstr "Додаје адресу у списак мејлинг листа са претплатом"

#: alias/commands.c:381
msgid "subscribe [ -group <name> ... ] <regex> [ ... ]"
msgstr "subscribe [ -group <назив> ... ] <регизр> [ ... ]"

#: alias/commands.c:384
msgid "Remove an alias definition"
msgstr "Уклања дефиницију алијаса"

#: alias/commands.c:385
msgid "unalias { * | <key> ... }"
msgstr "unalias { * | <тастер> ... }"

#: alias/commands.c:388
msgid "Remove addresses from `alternates` list"
msgstr "Уклања адресе из листе алтернативних адреса"

#: alias/commands.c:389
msgid "unalternates { * | <regex> ... }"
msgstr "unalternates { * | <регизр> ... }"

#: alias/commands.c:392
msgid "Remove addresses from an address `group`"
msgstr "Уклања адресе из групе адреса"

#: alias/commands.c:393
msgid "ungroup [ -group <name> ... ] { * | -rx <regex> ... | -addr <address> ... }"
msgstr "ungroup [ -group <назив> ... ] { * | -rx <регизр> ... | -addr <адреса> ... }"

#: alias/commands.c:396
msgid "Remove address from the list of mailing lists"
msgstr "Уклања заглавље из списка мејлинг листа"

#: alias/commands.c:397
msgid "unlists { * | <regex> ... }"
msgstr "unlists { * | <регизр> ... }"

#: alias/commands.c:400
msgid "Remove address from the list of subscribed mailing lists"
msgstr "Уклања адресу из списка мејлинг листа са претплатом"

#: alias/commands.c:401
msgid "unsubscribe { * | <regex> ... }"
msgstr "unsubscribe { * | <регизр> ... }"

