msgstr "  -h, --help           Komut satırı seçeneklerine genel bakış"

#: usage.c:192
msgid "  -h, --help <mode>    Detailed help for: shared, help, info, send, tui, all"
msgstr "  -h, --help <kip>     Ayrıntılı yardım: shared, help, info, send, tui, all"

#: usage.c:193
msgid "  -v, --version        NeoMutt version and build parameters"
msgstr "  -v, --version        NeoMutt sürümü ve yapı parametreleri"

#: usage.c:194
msgid "  -vv, --license       NeoMutt Copyright and license"
msgstr "  -vv, --license       NeoMutt telif hakkı ve lisansı"

#. L10N: Examples
#: usage.c:203
msgid "  neomutt --help info"
msgstr "  neomutt --help info"

#: usage.c:204
msgid "  neomutt --license"
msgstr "  neomutt --license"

#. L10N: Parameters in <>s may be translated
#: usage.c:218
msgid "  -A, --alias <alias> [...]   Lookup email aliases"
msgstr "  -A, --alias <arma> [...]    E-posta armalarını ara"

#: usage.c:219
msgid "                              Multiple aliases can be looked up (space-separated)"
msgstr "                              Birden çok arma aranabilir (boşlukla ayırın)"

#: usage.c:222
msgid "  -D, --dump-config           Dump all the config options"
msgstr "  -D, --dump-config           Tüm yapılandıma seçeneklerini dök"

#: usage.c:223
msgid "  -DD, --dump-changed-config  Dump the changed config options"
msgstr "  -DD, --dump-changed-config  Değiştirilmiş seçenekleri dök"

#: usage.c:226
msgid "  -Q, --query <option> [...]  Query config options"
msgstr "  -Q, --query <seçenek> [...] Yapılandırma seçeneklerini sorgula"

#: usage.c:227
msgid "                              Multiple options can be looked up (space-separated)"
msgstr "                              Birden çok seçenek aranabilir (boşlukla ayırın)"

#: usage.c:229
msgid "Modify the -D and -Q options:"
msgstr "-D ve -Q seçeneklerinde değişiklik yapın:"

#: usage.c:230
msgid "  -O, --with-docs             Add one-liner documentation"
msgstr "  -O, --with-docs             Tek satırlık bilgi ekle"

#: usage.c:231
msgid "  -S, --hide-sensitive        Hide the value of sensitive options"
msgstr "  -S, --hide-sensitive        Hassas seçeneklerin değerini gizle"

#. L10N: Examples
#: usage.c:240
msgid "  neomutt --alias flatcap gahr"
msgstr "  neomutt --alias bilge ayça"

#: usage.c:241
msgid "  neomutt --dump-config --with-docs"
msgstr "  neomutt --dump-config --with-docs"

#: usage.c:242
msgid "  neomutt --dump-changed-config --hide-sensitive"
msgstr "  neomutt --dump-changed-config --hide-sensitive"

#: usage.c:243
msgid "  neomutt --with-docs --query alias_format index_format"
msgstr "  neomutt --with-docs --query alias_format index_format"

#: usage.c:256
msgid "These options can supply everything NeoMutt needs to send an email."
msgstr ""
"Bu seçenekler, NeoMutt'ın e-posta gönderebilmesi için gerekli her şeyi sağlar."

#: usage.c:257
msgid "If any parts are missing, NeoMutt will start the TUI to ask for them."
msgstr "Eksik bir kısım varsa NeoMutt onları sormak için TUI'yi başlatır."

#: usage.c:258
msgid "Addresses may be used before the options, or after a -- marker."
msgstr ""
"Adresler seçeneklerden önce veya -- imleyicisinden sonra kullanılabilir."

#: usage.c:259
msgid "Aliases may be used in place of addresses."
msgstr "Adreslerin yerine armalar kullanılabilir."

#. L10N: Parameters in <>s may be translated
#: usage.c:263
msgid "  -a, --attach <file> [...]   Attach files"
msgstr "  -a, --attach <dosya> [...]  Dosyalar iliştir"

#: usage.c:264
msgid "                              Terminated by -- or another option"
msgstr "                              -- veya başka bir seçenekle sonlandırılır"

#: usage.c:265
msgid "  -b, --bcc <address>         Add Bcc: address"
msgstr "  -b, --bcc <adres>           Bcc: (gizli kopya) adresi ekle"

#: usage.c:266
msgid "  -C, --crypto                Use crypto (signing/encryption)"
msgstr "  -C, --crypto                Kripto kullan (imza/şifre)"

#: usage.c:267
msgid "                              Must be set up in the config file"
msgstr "                              Yapılandırma dosyasında ayarlanmalıdır"

#: usage.c:268
msgid "  -c, --cc <address>          Add Cc: address"
msgstr "  -c, --cc <adres>            Cc: (kopya) adresi ekle"

#: usage.c:269
msgid "  -E, --edit-message          Edit message (draft/include)"
msgstr "  -E, --edit-message          İletiyi düzenle (taslak/içer)"

#: usage.c:270
msgid "                              (supplied by -H or -i)"
msgstr "                              (-H veya -i ile sağlanır)"

#: usage.c:271
msgid "  -H, --draft <file>          Use draft email file"
msgstr "  -H, --draft <dosya>         Taslak e-postayı kullan"

#: usage.c:272
msgid "                              Full email with headers and body"
msgstr "                              Üstbilgi ve gövde ile tam e-posta"

#: usage.c:273
msgid "  -i, --include <file>        Include body file"
msgstr "  -i, --include <dosya>       Gövde dosyası içer"

#: usage.c:274
msgid "  -s, --subject <subject>     Set Subject:"
msgstr "  -s, --subject <konu>        Subject: (konuyu) ayarla"

#: usage.c:275
msgid "  -- <address> [...]          Add To: addresses"
msgstr "  -- <adres> [...]            To: (kime) adresi ekle"

#. L10N: Examples: Filenames and email subjects may be translated
#: usage.c:284
msgid "  neomutt flatcap --subject 'Meeting' < meeting.txt"
msgstr "  neomutt hakan --subject 'Toplantı' < toplantı.txt"

#: usage.c:285
msgid "  neomutt jim@example.com --cc bob@example.com --subject 'Party' --include party.txt"
msgstr "  neomutt aylin@örnek.com --cc aysu@örnek.com --subject 'Parti' --include parti.txt"

#: usage.c:286
msgid "  neomutt --subject 'Receipts' --attach receipt1.pdf receipt2.pdf -- rocco"
msgstr "  neomutt --subject 'Makbuzlar' --attach makbuz1.pdf makbuz2.pdf -- patron"

#: usage.c:287
msgid "  cat secret.txt | neomutt gahr --subject 'Secret' --crypto"
msgstr "  cat gizli.txt | neomutt umay --subject 'Gizli' --crypto"

#: usage.c:300
msgid "Running NeoMutt with no options will read the config and start the TUI."
msgstr ""
"NeoMutt'ı seçenek vermeden çalıştırmak yapılandırmayı okur ve TUI'yi başlatır."

#: usage.c:301
msgid "By default, it will open the Index Dialog with the $spool_file Mailbox."
msgstr "Öntanımlı olarak, $spool_file posta kutusuyla indeks penceresini açar."

#: usage.c:304
msgid "These options cause NeoMutt to check a mailbox for mail."
msgstr "Bu seçenekler, NeoMutt'ın posta için posta kutusunu denetlemesini sağlar."

#: usage.c:305
msgid "If the condition isn't matched, NeoMutt exits."
msgstr "Koşul eşleşmezse NeoMutt çıkar."

#: usage.c:306
msgid "  -p, --postponed       Resume postponed email"
msgstr "  -p, --postponed       Ertelenen postayı sürdür"

#: usage.c:307
msgid "  -Z, --check-new-mail  Check for new mail"
msgstr "  -Z, --check-new-mail  Yeni postayı denetle"

#: usage.c:308
msgid "  -z, --check-any-mail  Check for any mail"
msgstr "  -z, --check-any-mail  Herhangi bir postayı denetle"

#. L10N: Parameters in <>s may be translated
#: usage.c:312
msgid "These options change the starting behavior:"
msgstr "Bu seçenekler, başlatma davranışını değiştirir:"

#: usage.c:313
msgid "  -f, --folder <mailbox>      Open this mailbox"
msgstr "  -f, --folder <kutu>         Bu posta kutusunu aç"

#: usage.c:314
msgid "  -G, --nntp-browser          Open NNTP browser"
msgstr "  -G, --nntp-browser          NNTP tarayıcısını aç"

#: usage.c:315
msgid "  -g, --nntp-server <server>  Use this NNTP server"
msgstr "  -g, --nntp-server <sunucu>  Bu NNTP sunucusunu kullan"

#: usage.c:316
msgid "  -R, --read-only             Open mailbox read-only"
msgstr "  -R, --read-only             Posta kutusunu saltokunur aç"

#: usage.c:317
msgid "  -y, --browser               Open mailbox browser"
msgstr "  -y, --browser               Posta kutusu tarayıcısını aç"

#. L10N: Examples: Path may be translated
#: usage.c:326
msgid "  neomutt --folder ~/mail --check-new-mail"
msgstr "  neomutt --folder ~/mail --check-new-mail"

#: usage.c:327
msgid "  neomutt --postponed"
msgstr "  neomutt --postponed"

#: usage.c:328
msgid "  neomutt --browser"
msgstr "  neomutt --browser"

